# Copie ce fichier en .env puis remplis les valeurs.
# Le .env est gitignored — jamais commité.

# ─── Compte MT5 ────────────────────────────────────────────────────
MT5_LOGIN=10010590722
MT5_PASSWORD=your_password_here
MT5_SERVER=MetaQuotes-Demo

# ─── Sécurité du bridge ────────────────────────────────────────────
# Clé partagée entre le bridge et le client (le backend Scalping Radar).
# Si vide : le bridge en génère une au démarrage et l'affiche dans la console.
BRIDGE_API_KEY=

# ─── Mode ───────────────────────────────────────────────────────────
# true  = paper-trade (log seulement, aucun ordre réel envoyé à MT5)
# false = live (non encore implémenté — garde true pour le moment)
PAPER_MODE=true

# ─── Limites hard ──────────────────────────────────────────────────
# Lot max par trade. Le bridge refuse tout ordre au-dessus.
MAX_LOT=0.1

# ─── Réseau ─────────────────────────────────────────────────────────
# Bind sur loopback uniquement pour l'instant.
LISTEN_HOST=127.0.0.1
LISTEN_PORT=8787
