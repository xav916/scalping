# Server
HOST=0.0.0.0
PORT=8000

# DuckDNS + HTTPS (Let's Encrypt)
# 1. Creer un compte sur https://www.duckdns.org
# 2. Creer un sous-domaine et copier le token
DOMAIN=scalping-radar.duckdns.org
DUCKDNS_TOKEN=

# Authentification (laisser vide = acces libre)
# Option 1 : un seul utilisateur
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme
# Option 2 : plusieurs utilisateurs (format user:pass,user2:pass2)
AUTH_USERS=xav:monpass,invite:sonpass

# Scraping intervals (seconds)
MATAF_POLL_INTERVAL=300
FOREXFACTORY_POLL_INTERVAL=600

# Analysis thresholds
VOLATILITY_THRESHOLD_HIGH=1.5
VOLATILITY_THRESHOLD_MEDIUM=1.2
TREND_STRENGTH_MIN=0.6

# Source de prix :
#   "twelvedata" = API REST (gratuit 800 req/jour, polling 1min min)
#   "mt5"        = MetaTrader 5 en temps reel (requiert MT5 desktop + lib MetaTrader5)
PRICE_SOURCE=twelvedata

# --- Option 1 : Twelve Data API ---
# Gratuit: 8 req/min, 800/jour. Inscription https://twelvedata.com/register
# Sans cle, l'outil fonctionne avec des donnees simulees.
TWELVEDATA_API_KEY=

# --- Option 2 : MetaTrader 5 (temps reel) ---
# Requiert : MT5 desktop installe et lance + pip install MetaTrader5
# Le terminal MT5 doit etre lance sur la meme machine que le radar.
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
# Chemin vers terminal64.exe (optionnel si MT5 est deja lance)
# Windows : C:\Program Files\OANDA TMS Brokers MT5\terminal64.exe
MT5_TERMINAL_PATH=
# Mapping paires -> symboles broker (obligatoire pour OANDA TMS et autres brokers a suffixe)
# Exemple OANDA TMS : XAU/USD:GOLD.pro,EUR/USD:EURUSD.pro,GBP/USD:GBPUSD.pro,USD/JPY:USDJPY.pro
MT5_SYMBOL_MAP=

# Money management
TRADING_CAPITAL=10000
RISK_PER_TRADE_PCT=1.0
MIN_CONFIDENCE_SCORE=75

# Intervalle des bougies pour l'analyse de patterns
CANDLE_INTERVAL=5min
CANDLE_COUNT=50

# Pour tester uniquement l'or :
# WATCHED_PAIRS=XAU/USD
# Pour tout surveiller :
WATCHED_PAIRS=XAU/USD,EUR/USD,GBP/USD,USD/JPY,EUR/GBP,USD/CHF,AUD/USD,USD/CAD,EUR/JPY,GBP/JPY
