# Server
HOST=0.0.0.0
PORT=8000

# DuckDNS + HTTPS (Let's Encrypt)
# 1. Creer un compte sur https://www.duckdns.org
# 2. Creer un sous-domaine et copier le token
DOMAIN=scalping-radar.duckdns.org
DUCKDNS_TOKEN=

# Authentification (laisser vide = acces libre)
# Option 1 : un seul utilisateur
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme
# Option 2 : plusieurs utilisateurs (format user:pass,user2:pass2)
# Les usernames peuvent etre des emails (le dernier ":" separe login et password)
AUTH_USERS=couderc.xavier@gmail.com:motdepasse1,c.chaussis@icloud.com:motdepasse2
# Noms d'affichage par utilisateur (format user:DisplayName,user2:DisplayName2)
# Si absent, le prefixe avant @ est utilise (ex: couderc.xavier pour email)
AUTH_DISPLAY_NAMES=couderc.xavier@gmail.com:Xav,c.chaussis@icloud.com:Ced

# Scraping intervals (seconds)
# Twelve Data gratuit (800 req/jour) : garder 10 paires @ 300s depasse la limite.
# Configuration recommandee pour plan gratuit : 2 paires @ 180s = ~960 req/j (tolere).
# Configuration recommandee pour plan Grow : 10 paires @ 180s = 4800 req/j (sous 5000).
MATAF_POLL_INTERVAL=180
FOREXFACTORY_POLL_INTERVAL=600

# Analysis thresholds
VOLATILITY_THRESHOLD_HIGH=1.5
VOLATILITY_THRESHOLD_MEDIUM=1.2
TREND_STRENGTH_MIN=0.6

# Source de prix :
#   "twelvedata" = API REST (gratuit 800 req/jour, polling 1min min)
#   "mt5"        = MetaTrader 5 en temps reel (requiert MT5 desktop + lib MetaTrader5)
PRICE_SOURCE=twelvedata

# --- Option 1 : Twelve Data API ---
# Gratuit: 8 req/min, 800/jour. Inscription https://twelvedata.com/register
# Sans cle, l'outil fonctionne avec des donnees simulees.
TWELVEDATA_API_KEY=

# WebSocket Twelve Data : ticks temps reel <1s (requiert plan Grow ou plus)
# Limite reelle du plan Grow = 2 symboles simultanes en WebSocket.
# Pour streamer plus, passer au plan Pro (jusqu'a 80 symboles).
TWELVEDATA_WS_ENABLED=false
TWELVEDATA_WS_MAX_SYMBOLS=2

# --- Telegram bot (notifications mobiles des signaux) ---
# 1. Parler a @BotFather sur Telegram -> /newbot -> copier le token
# 2. Envoyer "bonjour" a votre bot depuis votre compte Telegram
# 3. Ouvrir https://api.telegram.org/bot<TOKEN>/getUpdates pour recuperer chat_id
TELEGRAM_BOT_TOKEN=
# --- Mode 1 (simple) : un seul destinataire ---
TELEGRAM_CHAT_ID=
# --- Mode 2 (multi-users avec silent mode par user) ---
# Chaque user a son propre chat_id, son silent mode est verifie independamment.
# Format: user1:chat_id1,user2:chat_id2 (le user doit matcher celui dans AUTH_USERS)
# Si renseigne, TELEGRAM_CHAT_ID est ignore.
TELEGRAM_CHATS=
# Force minimum pour envoi Telegram : weak / moderate / strong
TELEGRAM_MIN_STRENGTH=strong

# --- Option 2 : MetaTrader 5 (temps reel) ---
# Requiert : MT5 desktop installe et lance + pip install MetaTrader5
# Le terminal MT5 doit etre lance sur la meme machine que le radar.
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
# Chemin vers terminal64.exe (optionnel si MT5 est deja lance)
# Windows : C:\Program Files\OANDA TMS Brokers MT5\terminal64.exe
MT5_TERMINAL_PATH=
# Mapping paires -> symboles broker (obligatoire pour OANDA TMS et autres brokers a suffixe)
# Exemple OANDA TMS : XAU/USD:GOLD.pro,EUR/USD:EURUSD.pro,GBP/USD:GBPUSD.pro,USD/JPY:USDJPY.pro
MT5_SYMBOL_MAP=

# Money management
TRADING_CAPITAL=10000
RISK_PER_TRADE_PCT=1.0
MIN_CONFIDENCE_SCORE=75

# Intervalle des bougies pour l'analyse de patterns
CANDLE_INTERVAL=5min
CANDLE_COUNT=50

# Paires surveillees (ajuster selon le plan Twelve Data)
# Plan gratuit (800 req/j) : max 2 paires @ 180s de polling
# Plan Grow 29$/mo (5000 req/j) : jusqu'a 10 paires @ 180s
# Plan Pro 79$/mo : 10+ paires @ 60s possible
WATCHED_PAIRS=XAU/USD,EUR/USD
# Panier complet (necessite plan Grow minimum) :
# WATCHED_PAIRS=XAU/USD,EUR/USD,GBP/USD,USD/JPY,EUR/GBP,USD/CHF,AUD/USD,USD/CAD,EUR/JPY,GBP/JPY

# --- Email summary quotidien (optionnel) ---
# Envoie un recap a 22h UTC chaque jour. Compatible Gmail/Sendgrid/etc.
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM=
# Plusieurs destinataires separes par virgule
EMAIL_RECIPIENTS=

# Macro context scoring (Vague 1)
MACRO_SCORING_ENABLED=false
MACRO_VETO_ENABLED=false
MACRO_REFRESH_INTERVAL_SEC=900
MACRO_CACHE_MAX_AGE_SEC=7200
